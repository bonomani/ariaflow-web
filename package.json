{
  "name": "ariaflow-dashboard-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript sources for the ariaflow-dashboard frontend (bundled into src/ariaflow_dashboard/static/dist/).",
  "type": "module",
  "scripts": {
    "build": "npm run build:js && npm run build:html",
    "build:js": "esbuild src/ariaflow_dashboard/static/ts/main.ts --bundle --format=esm --target=es2020 --sourcemap --outfile=src/ariaflow_dashboard/static/dist/app.js",
    "build:html": "node scripts/build-html.mjs",
    "dev": "npm run build:js -- --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ariaflow_dashboard/static/ts",
    "format": "prettier --write src/ariaflow_dashboard/static/ts",
    "format:check": "prettier --check src/ariaflow_dashboard/static/ts",
    "test": "node --import tsx --test 'src/ariaflow_dashboard/static/ts/*.test.ts'",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "freshness:snapshot": "node scripts/freshness-snapshot.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/alpinejs": "^3.13.10",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
