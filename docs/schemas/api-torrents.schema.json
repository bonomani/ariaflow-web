{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bonomani/ariaflow-dashboard/docs/schemas/api-torrents.schema.json",
  "title": "GET /api/torrents response (frontend contract)",
  "type": "object",
  "required": ["torrents"],
  "properties": {
    "torrents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "infohash": {"type": "string"},
          "name":     {"type": "string"},
          "status":   {"type": "string"}
        }
      }
    }
  }
}
