{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bonomani/ariaflow-dashboard/docs/schemas/api-lifecycle.schema.json",
  "title": "GET /api/lifecycle response (frontend contract)",
  "description": "Frontend-owned shape contract for /api/lifecycle. The response is a flat object: per-target entries keyed by target name (each with meta + result), plus session metadata at the top level.",
  "type": "object",
  "properties": {
    "session_id":           {"type": ["string", "null"]},
    "session_started_at":   {"type": ["string", "null"]},
    "session_last_seen_at": {"type": ["string", "null"]}
  },
  "patternProperties": {
    "^(?!session_).*$": {
      "type": "object",
      "properties": {
        "meta": {
          "type": "object",
          "properties": {
            "contract": {"type": "string"}
          }
        },
        "result": {
          "type": "object",
          "properties": {
            "outcome":     {"type": "string"},
            "observation": {"type": "string"},
            "reason":      {"type": "string"},
            "message":     {"type": "string"}
          }
        }
      }
    }
  }
}
